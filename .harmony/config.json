    { "name": "Integration Test", "command": "./scripts/integration-test.sh" },
    { "name": "Build whisper.cpp", "command": "./scripts/build-whisper-lib.sh" },
    { "name": "Run App", "command": "open build/AudioInput.app" }
  ],
  "links": [
